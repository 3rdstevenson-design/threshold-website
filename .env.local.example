# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local — it is gitignored.

# Meta / Instagram (see Phase 1 in the spec)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Vercel Blob (create a Blob Store in your Vercel project dashboard)
BLOB_READ_WRITE_TOKEN=

# Cron protection — any random string, must match what Vercel sends
CRON_SECRET=

# Dashboard password — used to protect dashboard.thresholdhp.com
DASHBOARD_PASSWORD=
